# publish.env.example -- template for scripts/publish-channel.ps1 config.
#
# Copy to scripts/publish.env and fill in values for your hub. Do NOT
# check the real publish.env in; it contains the hub owner token.
# (scripts/publish.env is in .gitignore; this example file is not.)
#
# Process environment variables of the same name override anything set
# here, so CI and one-shot overrides work without editing the file.

# Base URL of the target hub. No trailing slash.
TELA_PUBLISH_HUB_URL=https://hub.example.net

# Owner or admin token for the hub. Retrieve with:
#   telahubd user show-owner
# On a Dockerised hub:
#   docker exec <container> telahubd user show-owner -config /app/data/telahubd.yaml
TELA_PUBLISH_TOKEN=

# Optional: override the channel, repo root, and dist directory.
# Defaults: channel read from scripts/channel.txt (created with "local"
# if absent); repo root = this script's parent directory; dist = <repo>/dist.
# TELA_PUBLISH_CHANNEL=local
# TELA_PUBLISH_REPO_ROOT=C:\src\tela
# TELA_PUBLISH_DIST_DIR=C:\src\tela\dist
